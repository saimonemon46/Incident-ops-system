# Database connection string for SQLAlchemy
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/incidents_db

# JWT secret key for token signing
JWT_SECRET=your_jwt_secret_here
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional Redis URL for caching or rate limiting
REDIS_URL=redis://localhost:6379/0

# Optional Slack alerting webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Optional SendGrid settings for email alerts
SENDGRID_API_KEY=SG.your_sendgrid_key
SENDGRID_FROM_EMAIL=alerts@yourapp.com

# SLA settings in minutes
SLA_CRITICAL_MINUTES=15
SLA_HIGH_MINUTES=60
